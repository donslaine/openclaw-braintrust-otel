{
  "id": "braintrust-otel",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "endpoint": { "type": "string" },
      "tracesEndpoint": { "type": "string" },
      "serviceName": { "type": "string" },
      "tags": { "type": "array", "items": { "type": "string" } },
      "captureContent": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "input": { "type": "boolean" },
          "output": { "type": "boolean" },
          "toolInputs": { "type": "boolean" },
          "toolOutputs": { "type": "boolean" },
          "systemPrompt": { "type": "boolean" }
        }
      },
      "sessionIdentifiers": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "raw": { "type": "boolean" },
          "hash": { "type": "boolean" },
          "hashSaltSecretRef": { "type": "string" }
        }
      }
    }
  }
}
