{
  "name": "@donslaine/openclaw-braintrust-otel",
  "version": "0.3.2",
  "description": "OpenClaw plugin: subscribes to internal diagnostics and emits Braintrust-shaped OTEL spans",
  "license": "MIT",
  "author": "donslaine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donslaine/openclaw-braintrust-otel.git"
  },
  "homepage": "https://github.com/donslaine/openclaw-braintrust-otel#readme",
  "bugs": "https://github.com/donslaine/openclaw-braintrust-otel/issues",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "braintrust",
    "opentelemetry",
    "otel",
    "observability"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspect:real": "tsx scripts/inspect-real.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "openclaw": "^2026.5.20",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.20",
      "minGatewayVersion": "2026.5.20"
    },
    "build": {
      "openclawVersion": "2026.5.20",
      "pluginSdkVersion": "2026.5.20"
    },
    "install": {
      "npmSpec": "@donslaine/openclaw-braintrust-otel",
      "defaultChoice": "npm"
    }
  }
}
